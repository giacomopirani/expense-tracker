{
  "compilerOptions": {
    /* === File Layout === */
    "rootDir": "src",
    "outDir": "dist",

    /* === Environment Settings === */
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "lib": ["esnext"],
    "types": ["node"],

    /* === Output === */
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,

    /* === Strict Type Checking === */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
